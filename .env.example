# Telegram Bot Token (получить у @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# AI-провайдеры (бот пробует в порядке: Groq → Gemini → OpenAI)
# Достаточно указать хотя бы один ключ

# Groq API Key (бесплатно, быстрый, https://console.groq.com/keys)
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini API Key (бесплатно, https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key (платный, https://platform.openai.com/api-keys)
OPENAI_API_KEY=your_openai_api_key_here

# ID администраторов бота (через запятую), которые могут добавлять данные в базу
ADMIN_IDS=123456789,987654321
